# AdSense Configuration
# Set to "true" to enable ads in production
NEXT_PUBLIC_ADS_ENABLED=false

# Your AdSense publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
# Get this from your AdSense account after approval
NEXT_PUBLIC_ADSENSE_CLIENT=

# Ad Unit Slot IDs (get these from AdSense after creating ad units)
# Format: XXXXXXXXXX (10 digits)
# Homepage
NEXT_PUBLIC_AD_SLOT_HOME_HERO=
NEXT_PUBLIC_AD_SLOT_HOME_MID=

# Blog Posts
NEXT_PUBLIC_AD_SLOT_ARTICLE_TOP=
NEXT_PUBLIC_AD_SLOT_ARTICLE_MID=
NEXT_PUBLIC_AD_SLOT_ARTICLE_BOTTOM=
NEXT_PUBLIC_AD_SLOT_SIDEBAR=

# Pillar Pages
NEXT_PUBLIC_AD_SLOT_PILLAR_TOP=
NEXT_PUBLIC_AD_SLOT_PILLAR_MID=
NEXT_PUBLIC_AD_SLOT_PILLAR_BOTTOM=

# Optional: engagement tracking endpoint (POST JSON)
# Example: https://analytics.example.com/events
NEXT_PUBLIC_EVENT_ENDPOINT=

# OpenAI Image Pipeline (server-side only)
OPENAI_API_KEY=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
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1536x1024

# Instructions:
# 1. Copy this file to .env.local
# 2. After AdSense approval, add your publisher ID
# 3. Create ad units in AdSense dashboard
# 4. Add the slot IDs above
# 5. Set NEXT_PUBLIC_ADS_ENABLED=true
# 6. Rebuild and deploy
